  "keyFeatures": [
    "Semantic code search with 98% token reduction",
    "Hybrid vector + keyword search with RRF ranking",
    "Context compression (70-98% reduction)",
    "Persistent memory across sessions",
    "Multi-level L1/L2 cache with TTL",
    "MCP server for AI assistant integration",
    "REST API with Swagger documentation",
    "Multiple embedding providers (Ollama, Mistral, OpenAI)"
  ],
  "publicApiSurface": [
    "th0th_index - Index a project directory for semantic search",
    "th0th_index_status - Check background indexing job progress",
    "th0th_search - Semantic + keyword search with filters",
    "th0th_remember - Store important information in persistent memory",
    "th0th_recall - Search stored memories from previous sessions",
    "th0th_compress - Compress context (keeps structure, removes details)",
    "th0th_optimized_context - Search + compress in one call",
    "th0th_analytics - Usage patterns, cache performance, metrics",
    "POST /api/v1/project/index - Index a project via REST API",
    "POST /api/v1/search/project - Search indexed projects",
    "POST /api/v1/memory/store - Store memory entries",
    "POST /api/v1/context/compress - Compress code context",
    "th0th-config CLI - Configuration management tool"
  ]
